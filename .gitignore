datasets/
ml-runs/

# landing-rebuild skill outputs (generated Next.js apps + extractions, large)
projects/nexuspoint-landing/
projects/*-landing/

# Expense Calculator: its own standalone git repo (github.com/Qubit1010/expense-calculator-pwa),
# deployed separately to Vercel. Not part of the Nexis monorepo.
projects/ExpenseCalculator/

# Webots robotics projects (large, generated worlds/archives)
webots-projects/
webots-projects.rar

# Claude Playbook lead-magnet: ignore the 30 individual section PDFs (build artifacts).
# Keep the front-matter PDF and the merged The-Practical-Claude-Playbook-FULL.pdf.
.claude/skills/claude-advisor/references/playbook-*.pdf
# Same for the 30 individual playbook section .md drafts (build artifacts).
.claude/skills/claude-advisor/references/playbook-*.md

# Capability catalog (generated PDFs + build script)
catalog/

# Archived/superseded material
archives/

# Decision log (private/sensitive)
/decisions/

# Research source indexes and run logs (large, regenerable)
**/_research/sources.json
**/_research/sources-raw.json
**/_research/*.log

# Playwright CLI session logs
**/.playwright-cli/

# GDrive sync: OAuth token + local folder ID cache (machine-specific)
**/gdrive_token.json
**/folder_ids.json

# Eval workspaces (large run outputs, not needed in repo)
**/*-workspace/

# Impeccable cache files
**/.impeccable/

# Understand-Anything plugin output
.understand-anything/

# HyperFrames video render output (large binaries, generated per-run)
/videos/

# University files (assignments, coursework, private)
university/

# Client project files (confidential)
client-projects/

# Model configs (local, not shared)
.claude/glm/
.claude/default/
.claude/deepseek-v4-flash/
.claude/deepseek-v4-pro/
.claude/open-models/

# Docs and references (large files, local only)
/docs/
/references/

# Personal/sensitive files
**/context.rar
**/nexuspoint-landing-page-copy.md
**/daily-os.md
references/Upwork/
references/marketing-books-notes/
.claude/rules/
