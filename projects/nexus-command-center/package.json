{
  "name": "nexus-command-center",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web \"node server/index.ts\" \"vite\"",
    "build": "vite build",
    "start": "node server/index.ts",
    "scan": "python scripts/build_system_graph.py",
    "typecheck": "tsc --noEmit",
    "test": "node --test server/server.test.ts && python scripts/test_build_system_graph.py"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "dompurify": "^3.4.11",
    "hono": "^4.6.0",
    "marked": "^18.0.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-2d": "^1.25.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
